# Agent Registry server environment variables.
# Source: agentregistry-dev/agentregistry .env.example (v0.3.3)

AGENT_REGISTRY_SERVER_ADDRESS=:8080
AGENT_REGISTRY_DATABASE_URL=postgres://postgres:postgres@postgres:5432/agentregistry?sslmode=disable
AGENT_REGISTRY_VERSION=v0.3.3

# Generate: openssl rand -hex 32 | base64
AGENT_REGISTRY_JWT_PRIVATE_KEY=CHANGEME

AGENT_REGISTRY_ENABLE_REGISTRY_VALIDATION=false
AGENT_REGISTRY_AGENT_GATEWAY_PORT=8081
