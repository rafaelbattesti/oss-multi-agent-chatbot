# Langfuse v3 environment variables — shared by langfuse-web and langfuse-worker.
# Source: https://langfuse.com/self-hosting/deployment/docker-compose

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Must match POSTGRES_PASSWORD in docker-compose.yaml.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/langfuse

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_MIGRATION_URL=clickhouse://default:@clickhouse:9000
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_AUTH=

# ── MinIO (S3-compatible) ─────────────────────────────────────────────────────
# Values must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in docker-compose.yaml.
LANGFUSE_S3_MEDIA_UPLOAD_ENABLED=true
LANGFUSE_S3_ENDPOINT=http://minio:9000
LANGFUSE_S3_ACCESS_KEY_ID=minio
LANGFUSE_S3_SECRET_ACCESS_KEY=miniosecret
LANGFUSE_S3_BUCKET_NAME=langfuse
LANGFUSE_S3_REGION=auto
LANGFUSE_S3_FORCE_PATH_STYLE=true

LANGFUSE_S3_EVENT_UPLOAD_ENABLED=true
LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_EVENT_UPLOAD_PREFIX=events/
LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=http://minio:9000
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=miniosecret
LANGFUSE_S3_EVENT_UPLOAD_REGION=auto
LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE=true

LANGFUSE_S3_BATCH_EXPORT_ENABLED=true
LANGFUSE_S3_BATCH_EXPORT_BUCKET=langfuse
LANGFUSE_S3_BATCH_EXPORT_PREFIX=batch-exports/
LANGFUSE_S3_BATCH_EXPORT_ENDPOINT=http://minio:9000
LANGFUSE_S3_BATCH_EXPORT_ACCESS_KEY_ID=minio
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=miniosecret
LANGFUSE_S3_BATCH_EXPORT_REGION=auto
LANGFUSE_S3_BATCH_EXPORT_FORCE_PATH_STYLE=true

# ── Auth & Encryption ─────────────────────────────────────────────────────────
# Generate each with: openssl rand -hex 32
LANGFUSE_SECRET_KEY=CHANGEME
NEXTAUTH_SECRET=CHANGEME
SALT=CHANGEME

NEXTAUTH_URL=http://localhost:3000

# ── Telemetry ─────────────────────────────────────────────────────────────────
TELEMETRY_ENABLED=true
